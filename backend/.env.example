# Copy to .env for local runs. Every value has a safe default, so an empty file also works
# and boots the in-memory backend with auth off.

# Blank selects the in-memory repo (dev/test). Set to a Postgres URL for production.
# CRYOSTASIS_DATABASE_URL=postgresql://user:pass@localhost:5432/cryostasis

# Enforce the session-proof handshake. When true, CRYOSTASIS_JWT_SECRET must be set to a
# real secret or the app refuses to start.
# CRYOSTASIS_REQUIRE_AUTH=true
# CRYOSTASIS_JWT_SECRET=change-me-to-a-long-random-string

# Presence window: a player is online while their last heartbeat is inside this many seconds.
# CRYOSTASIS_PRESENCE_WINDOW_SECONDS=120

# CDN base for texture URLs. The database stores only the object key.
# CRYOSTASIS_CDN_BASE_URL=https://cdn.cryostasis.ramon.moe

# Listen port (uvicorn). Defaults to 8080 in the container.
# CRYOSTASIS_PORT=8080
